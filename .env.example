# Copy this file to .env and fill in your key(s).
# .env is gitignored and never committed.

# Mistral is the default provider. Get a key at console.mistral.ai.
MISTRAL_API_KEY=

# Other providers (optional) — uncomment the ones you use.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_API_KEY=not-needed
